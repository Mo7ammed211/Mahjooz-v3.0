rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Public read: regions, categories, services (needed for signup & guest browsing)
    match /regions/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /categories/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /services/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Store System: public read so customers can browse stores and products
    match /stores/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /store_cats/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /store_products/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Users: only authenticated users can read/write their own doc
    match /users/{userId} {
      allow read, write: if request.auth != null;
    }

    // All other collections: authenticated only
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
