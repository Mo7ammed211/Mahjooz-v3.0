rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Public read: regions, categories, services (needed for signup & guest browsing)
    match /regions/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /categories/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /services/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Store System: public read so customers can browse stores and products
    match /stores/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /store_cats/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /store_products/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Users: only authenticated users can read/write their own doc
    match /users/{userId} {
      allow read, write: if request.auth != null;
    }

    // ═══════════════════════════════════════════════════════
    //  🔐 سجل تدقيق المحافظ — محمي من الحذف والتعديل
    //  Wallet Audit Log — append-only, no delete or update
    // ═══════════════════════════════════════════════════════
    match /wallet_audit_log/{logId} {
      // القراءة: للمستخدمين المصادق عليهم فقط
      allow read: if request.auth != null;
      // الإنشاء: مسموح للمستخدمين المصادق عليهم (التطبيق يكتب فقط)
      allow create: if request.auth != null;
      // التعديل والحذف: ممنوع تماماً — حتى للمدير
      allow update, delete: if false;
    }

    // ═══════════════════════════════════════════════════════
    //  💰 المحافظ — قراءة وكتابة للمصادق عليهم فقط
    // ═══════════════════════════════════════════════════════
    match /wallets/{uid} {
      allow read, write: if request.auth != null;
    }

    // ═══════════════════════════════════════════════════════
    //  📊 المعاملات — إنشاء فقط (لا حذف ولا تعديل)
    // ═══════════════════════════════════════════════════════
    match /transactions/{txId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // All other collections: authenticated only
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
